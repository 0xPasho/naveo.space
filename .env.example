# Postgres connection string. Must point to a Postgres instance with the
# pgvector extension already installed (CREATE EXTENSION vector).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Clerk auth — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# OpenRouter — used by Phase 2 LLM-judge checks AND scripts/blog/generate.ts
# via the Vercel `ai` SDK + `@openrouter/ai-sdk-provider`. All LLM calls
# route through OpenRouter so we can swap providers without touching code.
# Default models live in src/modules/llm/data.ts (judges) and
# scripts/blog/generate.ts (blog generator).
OPENROUTER_API_KEY=""

# Public site URL. Drives canonical URLs, sitemap entries, OG metadata,
# and the BlogPosting JSON-LD. Must match the production hostname.
NEXT_PUBLIC_SITE_URL="https://naveo.space"

# Stripe — gem packs paid in USD via Checkout. Without these, the
# `Buy` buttons in the gem-pack section return `stripe_not_configured`
# and the UI shows a friendly "coming soon". Set both to enable real
# payments end-to-end.
#   - SECRET_KEY: server-only, used to create Checkout Sessions.
#     test: sk_test_…  /  live: sk_live_…
#   - WEBHOOK_SECRET: signs every event Stripe POSTs to
#     /api/stripe/webhook. Get it from `stripe listen` in dev or from
#     the endpoint's "Signing secret" field in the Stripe dashboard.
#     Format: whsec_…
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
