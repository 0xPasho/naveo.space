# Postgres connection string. Must point to a Postgres instance with the
# pgvector extension already installed (CREATE EXTENSION vector).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Clerk auth — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# OpenRouter — used by Phase 2 LLM-judge checks via the Vercel `ai` SDK.
# All LLM calls route through OpenRouter so we can swap providers without
# touching code. Default models live in src/modules/llm/data.ts.
OPENROUTER_API_KEY=""
